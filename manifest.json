{
    "manifest_version": 3,
    "name": "Modrinth Auto Filter",
    "version": "1.1.0",
    "description": "ModrinthのVersionsページを開いた際、自動で指定のPlatformとVersionをパラメータにセットします。",
    "permissions": [
        "storage"
    ],
    "content_scripts": [
        {
        "matches": ["*://modrinth.com/*"],
        "js": ["content.js"],
        "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Modrinth Auto Filter"
    }
}